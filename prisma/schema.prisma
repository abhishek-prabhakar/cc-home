generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  relationMode      = "prisma"
}

model User {
  id        String     @id
  name      String?
  username  String     @unique
  email     String?
  source    UserSource
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  bookings  Booking[]

  @@map("user")
}

model UserOtp {
  id        String   @id
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  username  String   @unique @db.VarChar(10)
  otpHash   String   @map("otp_hash")

  @@map("user_otp")
}

model Vendor {
  id               String            @id
  username         String            @unique
  name             String
  mobileNumber     String
  email            String
  categoryId       String?
  paymentMode      PaymentMode?
  paymentDetails   String?
  profileImageName String?
  coverImageName   String?
  location         String?
  source           UserSource
  isActive         Boolean
  accountStatusMsg String?
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  primaryColor     String            @default("#4caf50")
  vendorPortfolio  VendorPortfolio[]
  services         VendorService[]
  vendorType       VendorType?       @relation(fields: [categoryId], references: [id])
  VendorFiles      VendorFiles[]
  JumbotronData    JumbotronData[]

  @@map("vendors")
}

model VendorPortfolio {
  id        String   @id
  vendorId  String
  serviceId String
  fileType  String
  fileName  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendorPortfolio")
}

model VendorFiles {
  id        String   @id
  vendorId  String
  fileType  String
  fileName  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendorfiles")
}

model Booking {
  id             String           @id
  orderId        String
  userId         String
  status         BookingStatus
  total          Int
  tax            Int
  discount       Int
  coupon         String?
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  user           User             @relation(fields: [userId], references: [id])
  bookingService BookingService[]
}

model BookingService {
  id              String        @id
  bookingId       String
  vendorServiceId String
  status          BookingStatus
  date            DateTime
  timeHour        Int
  duration        Int
  location        String
  cost            Int
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  updated_at      DateTime?     @default(now()) @db.Timestamp(6)
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorService   VendorService @relation(fields: [vendorServiceId], references: [id])
}

model VendorService {
  id             String           @id
  vendorId       String
  serviceId      String
  duration       Int
  cost           Int
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  fareMode       FareMode
  bookingService BookingService[]
  service        Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  vendor         Vendor           @relation(fields: [vendorId], references: [id])

  @@map("vendorServices")
}

model ServiceGroup {
  id               String             @id
  name             String
  vendorTypeId     String
  imageName        String?
  description      String
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  vendorType       VendorType         @relation(fields: [vendorTypeId], references: [id])
  serviceGroupItem ServiceGroupItem[]
  JumbotronData    JumbotronData[]

  @@map("serviceGroup")
}

model Service {
  id               String             @id
  name             String             @unique
  description      String
  imageName        String?
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  minHour          Int                @default(1)
  serviceGroupItem ServiceGroupItem[]
  vendorPortfolio  VendorPortfolio[]
  vendorService    VendorService[]
  JumbotronData    JumbotronData[]

  @@map("service")
}

model ServiceGroupItem {
  id         String       @id
  groupId    String
  serviceId  String
  isOptional Boolean      @default(false)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  group      ServiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  service    Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("serviceGroupItem")
}

model VendorType {
  id            String          @id
  name          String
  description   String
  keyName       String          @unique
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  serviceGroup  ServiceGroup[]
  vendor        Vendor[]
  JumbotronData JumbotronData[]

  @@map("vendorType")
}

model MemberRequest {
  id                     String                   @id
  fullName               String
  mobileNumber           String
  email                  String
  category               String
  socialUrl              String
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  memberRequestPortfolio MemberRequestPortfolio[]

  @@map("memberRequest")
}

model MemberRequestPortfolio {
  id            String        @id
  requestId     String
  imageName     String
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  memberRequest MemberRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("memberRequestPortfolio")
}

model JumbotronData {
  id             String          @id
  title          String          @unique
  description    String
  imageName      String?
  vendorTypeId   String?
  serviceGroupId String?
  serviceId      String?
  vendorId       String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  vendorType     VendorType?     @relation(fields: [vendorTypeId], references: [id])
  group          ServiceGroup?   @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  vendor         Vendor?         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  service        Service?        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  WebsiteSlider  WebsiteSlider[]
  WebsiteBanner  WebsiteBanner[]

  @@map("jumbotronData")
}

model WebsiteSlider {
  id          String        @id
  jumbotronId String
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  jumbotron   JumbotronData @relation(fields: [jumbotronId], references: [id], onDelete: Cascade)

  @@map("websiteSlider")
}

model WebsiteBanner {
  id          String         @id
  jumbotronId String
  targetPage  BannerLocation
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  jumbotron   JumbotronData  @relation(fields: [jumbotronId], references: [id], onDelete: Cascade)

  @@map("websiteBanner")
}

enum UserSource {
  ORGANIC
  MANUAL
}

enum PaymentMode {
  NET_BANKING
  UPI
}

enum BookingStatus {
  PENDING
  CANCELLED
  REJECTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
}

enum FareMode {
  FLAT
  HOURLY
}

enum BannerLocation {
  HOME_1
  HOME_2
  HOME_3
  SERVICE_RESULT_1
}
